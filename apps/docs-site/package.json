{
  "name": "awaitly-docs",
  "type": "module",
  "version": "1.30.2",
  "private": true,
  "description": "Documentation for awaitly",
  "scripts": {
    "predev": "pnpm run generate-rules",
    "dev": "astro dev",
    "start": "astro dev",
    "dev:root": "BASE=/ astro dev",
    "build": "pnpm run generate-api && pnpm run generate-rules && astro build",
    "generate-api": "pnpm run -C ../.. generate-api",
    "generate-rules": "node scripts/generate-rule-pages.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^5.0.2",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/starlight": "^0.39.2",
    "@base-ui/react": "^1.4.1",
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.2",
    "astro-mermaid": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.15.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "starlight-theme-next": "^0.4.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "awaitly": "workspace:*",
    "awaitly-analyze": "workspace:*",
    "eslint-plugin-awaitly": "workspace:*",
    "tw-animate-css": "^1.4.0",
    "vitest": "^4.1.7"
  }
}

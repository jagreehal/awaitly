---
// "How it works" — a single visual that shows step() unwrapping Results and short-circuiting.
// Built with semantic HTML + CSS; no images, no chart libs.
const steps = [
  { id: 'getOrder',  errors: ['ORDER_NOT_FOUND'] },
  { id: 'getUser',   errors: ['USER_NOT_FOUND'] },
  { id: 'charge',    errors: ['CHARGE_DECLINED', 'INSUFFICIENT_FUNDS'] },
];
---

<section class="landing-section concept" aria-labelledby="concept-heading">
  <div class="landing-inner">
    <header class="concept__header">
      <span class="landing-eyebrow">02 · Mental model</span>
      <h2 class="landing-h2" id="concept-heading">
        Steps <em>unwrap</em>. Errors <em>short-circuit</em>.
      </h2>
      <p class="landing-lead">
        Every dependency that can fail returns a <code>Result</code>. <code>step()</code>
        either hands you the value and continues, or exits the workflow with the error.
        Your happy path stays linear. The error union grows, automatically, with each step you add.
      </p>
    </header>

    <div class="concept__diagram" role="img" aria-label="Workflow steps unwrap on success and short-circuit on error">
      <div class="concept__track">
        <div class="concept__rail" aria-hidden="true"></div>

        {steps.map((s, i) => (
          <div class="concept__node" style={`--i:${i}`}>
            <div class="concept__node-frame">
              <span class="concept__node-id">step {String(i + 1).padStart(2, '0')}</span>
              <code class="concept__node-name">{s.id}</code>
              <ul class="concept__node-errs">
                {s.errors.map((e) => (
                  <li><span class="concept__err-dot" aria-hidden="true"></span>{e}</li>
                ))}
              </ul>
            </div>
            <div class="concept__edge concept__edge--ok" aria-hidden="true">
              <span class="concept__edge-label">ok</span>
              <svg viewBox="0 0 24 12" preserveAspectRatio="none"><path d="M0 6 H22 M16 1 L22 6 L16 11" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </div>
        ))}

        <div class="concept__terminal" aria-hidden="true">
          <span class="concept__terminal-mark">✓</span>
          <span class="concept__terminal-label">return Charge</span>
        </div>
      </div>

      <div class="concept__exit" aria-hidden="true">
        {steps.map((_, i) => (
          <div class="concept__exit-line" style={`--i:${i}; --total:${steps.length}`}></div>
        ))}
        <div class="concept__exit-target">
          <span class="concept__exit-label">err</span>
          <code class="concept__exit-type">Result&lt;Charge, ORDER_NOT_FOUND | USER_NOT_FOUND | CHARGE_DECLINED | …&gt;</code>
        </div>
      </div>
    </div>

    <p class="concept__caption">
      Add <code>step.retry()</code>, <code>step.withTimeout()</code>, or <code>{`step('id', fn, { key })`}</code>
      and the same shape carries — TypeScript still tracks every error your dependencies can produce.
    </p>
  </div>
</section>

<style>
  .concept {
    padding-block: clamp(4.5rem, 9vw, 7.5rem);
  }

  .concept__header {
    max-width: 64ch;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .concept__header code {
    font-family: var(--mono);
    font-size: 0.88em;
    background: var(--ink-2);
    padding: 0.05em 0.35em;
    border-radius: 3px;
    color: var(--cream);
    border: 1px solid var(--line-soft);
  }

  .concept__diagram {
    position: relative;
    border: 1px solid var(--line);
    border-radius: 16px;
    background:
      linear-gradient(180deg, var(--ink-2) 0%, oklch(from var(--ink-2) l c h / 0.6) 100%);
    padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1.5rem, 4vw, 2.5rem) clamp(2rem, 5vw, 3.5rem);
    overflow: hidden;
  }

  .concept__track {
    position: relative;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    align-items: stretch;
  }
  @media (min-width: 56rem) {
    .concept__track {
      grid-template-columns: repeat(3, minmax(0, 1fr)) auto;
      gap: 0;
      align-items: center;
    }
  }

  .concept__rail {
    display: none;
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--line) 8%, var(--line) 92%, transparent);
    transform: translateY(-50%);
  }
  @media (min-width: 56rem) {
    .concept__rail { display: block; }
  }

  .concept__node {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .concept__node-frame {
    flex: 1;
    background: var(--ink);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 0.875rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    z-index: 1;
    transition: border-color 200ms ease, transform 200ms ease;
  }
  .concept__node-frame:hover {
    border-color: var(--amber-dim);
    transform: translateY(-2px);
  }

  .concept__node-id {
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cream-3);
  }
  .concept__node-name {
    font-family: var(--mono);
    font-size: 0.9375rem;
    color: var(--amber);
    letter-spacing: -0.01em;
  }
  .concept__node-errs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .concept__node-errs li {
    font-family: var(--mono);
    font-size: 0.6875rem;
    color: var(--cream-3);
    display: flex;
    align-items: center;
    gap: 0.45rem;
    letter-spacing: 0.04em;
  }
  .concept__err-dot {
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: var(--rust);
    flex-shrink: 0;
    box-shadow: 0 0 0 3px oklch(from var(--rust) l c h / 0.15);
  }

  .concept__edge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    color: var(--amber);
    padding: 0 0.5rem;
    z-index: 1;
  }
  .concept__edge svg {
    width: 28px;
    height: 14px;
  }
  .concept__edge-label {
    font-family: var(--mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--amber);
  }
  /* hide the trailing arrow on the last node — terminal handles it */
  .concept__node:last-of-type .concept__edge { display: none; }
  @media (max-width: 55.99rem) {
    .concept__edge { display: none; }
    .concept__node { display: block; }
  }

  .concept__terminal {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    padding: 0.875rem 1.125rem;
    border: 1px solid var(--amber-dim);
    background: oklch(from var(--amber) l c h / 0.08);
    border-radius: 10px;
    z-index: 1;
  }
  .concept__terminal-mark {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--amber);
    line-height: 1;
  }
  .concept__terminal-label {
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber);
  }

  .concept__exit {
    margin-top: clamp(2rem, 4vw, 3rem);
    padding-top: clamp(2rem, 4vw, 3rem);
    border-top: 1px dashed oklch(from var(--rust) l c h / 0.3);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .concept__exit-line {
    display: none;
  }

  .concept__exit-target {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .concept__exit-label {
    font-family: var(--mono);
    font-size: 0.625rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--rust);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .concept__exit-label::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--rust);
    border-radius: 999px;
  }
  .concept__exit-type {
    font-family: var(--mono);
    font-size: clamp(0.75rem, 1.1vw, 0.8125rem);
    color: var(--cream-2);
    background: var(--ink);
    border: 1px solid var(--line);
    padding: 0.625rem 0.75rem;
    border-radius: 8px;
    letter-spacing: -0.01em;
    line-height: 1.5;
    overflow-x: auto;
  }

  .concept__caption {
    margin: 1.75rem 0 0;
    font-family: var(--display);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--cream-3);
    max-width: 70ch;
  }
  .concept__caption code {
    font-family: var(--mono);
    font-size: 0.88em;
    color: var(--cream-2);
    background: var(--ink-2);
    padding: 0.05em 0.35em;
    border-radius: 3px;
    border: 1px solid var(--line-soft);
  }
</style>

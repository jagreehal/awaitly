---
import Hero from './Hero.astro';
import CodeDiff from './CodeDiff.astro';
import Concept from './Concept.astro';
import Pillars from './Pillars.astro';
import Compare from './Compare.astro';
import Cta from './Cta.astro';
---

<div class="landing-root">
  <Hero />
  <CodeDiff />
  <Concept />
  <Pillars />
  <Compare />
  <Cta />
</div>

<style is:global>
  /* Break out of Starlight's content container on the home page only.
     Splash template wraps content in .sl-markdown-content with constrained max-width. */
  .sl-markdown-content:has(> .landing-root),
  .sl-markdown-content:has(> p > .landing-root) {
    max-width: 100% !important;
  }
  .sl-markdown-content:has(> .landing-root) > * + * {
    margin-top: 0 !important;
  }

  /* Hide Starlight's PageTitle h1 only on the home page — we render our own. */
  main:has(.landing-root) > h1#_top,
  .main-frame:has(.landing-root) h1#_top,
  body:has(.landing-root) h1#_top {
    position: absolute !important;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
  /* Remove the leading content padding around our full-bleed landing */
  .sl-markdown-content:has(> .landing-root) {
    padding: 0 !important;
  }

  .landing-root {
    /* === Design tokens (dark-first, warm ink) === */
    --ink:        oklch(0.155 0.012 60);   /* near-black, warm */
    --ink-2:      oklch(0.205 0.012 60);   /* raised surface */
    --ink-3:      oklch(0.255 0.012 60);   /* card / hover */
    --line:       oklch(0.305 0.010 60);   /* divider */
    --line-soft:  oklch(0.245 0.008 60);   /* hairline */
    --cream:      oklch(0.965 0.012 80);   /* primary text */
    --cream-2:    oklch(0.840 0.012 80);   /* secondary text */
    --cream-3:    oklch(0.640 0.012 80);   /* tertiary text */
    --amber:      oklch(0.815 0.155 65);   /* primary accent — ok */
    --amber-2:    oklch(0.720 0.155 60);   /* hover */
    --amber-dim:  oklch(0.480 0.110 60);   /* low-key accent */
    --rust:       oklch(0.640 0.140 28);   /* err accent */
    --rust-dim:   oklch(0.420 0.090 28);

    --display: 'Schibsted Grotesk', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif;
    --mono: 'Geist Mono', ui-monospace, 'SF Mono', 'JetBrains Mono', monospace;

    /* break out of any constrained container */
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);

    background: var(--ink);
    color: var(--cream);
    font-family: var(--display);
    font-feature-settings: 'ss01', 'ss02', 'cv01', 'cv11';
    font-variant-ligatures: common-ligatures;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Light counterpart — Starlight uses data-theme="light" */
  :where([data-theme='light']) .landing-root {
    --ink:        oklch(0.985 0.008 80);
    --ink-2:      oklch(0.955 0.012 80);
    --ink-3:      oklch(0.925 0.012 80);
    --line:       oklch(0.860 0.012 80);
    --line-soft:  oklch(0.910 0.010 80);
    --cream:      oklch(0.180 0.015 60);
    --cream-2:    oklch(0.380 0.012 60);
    --cream-3:    oklch(0.540 0.012 60);
    --amber:      oklch(0.580 0.155 55);
    --amber-2:    oklch(0.500 0.155 55);
    --amber-dim:  oklch(0.700 0.090 55);
    --rust:       oklch(0.480 0.150 28);
    --rust-dim:   oklch(0.640 0.080 28);
  }

  .landing-root *,
  .landing-root *::before,
  .landing-root *::after {
    box-sizing: border-box;
  }

  /* Section frame — every landing section uses this */
  .landing-section {
    width: 100%;
    padding-inline: clamp(1.25rem, 5vw, 5rem);
    border-top: 1px solid var(--line-soft);
  }

  .landing-section--first {
    border-top: 0;
  }

  .landing-inner {
    max-width: 80rem;
    margin: 0 auto;
  }

  /* Eyebrow label — small caps mono, used on every section header */
  .landing-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cream-3);
  }
  .landing-eyebrow::before {
    content: '';
    width: 1.25rem;
    height: 1px;
    background: currentColor;
    opacity: 0.6;
  }

  /* Section heading — large display, leading tight */
  .landing-h2 {
    font-family: var(--display);
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.02;
    letter-spacing: -0.025em;
    margin: 1.25rem 0 0;
    color: var(--cream);
    text-wrap: balance;
  }
  .landing-h2 em {
    font-style: italic;
    font-weight: 600;
    color: var(--amber);
  }

  .landing-lead {
    font-family: var(--display);
    font-weight: 400;
    font-size: clamp(1rem, 1.4vw, 1.125rem);
    line-height: 1.55;
    color: var(--cream-2);
    max-width: 60ch;
    margin: 1.5rem 0 0;
  }

  /* Buttons */
  .landing-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1.25rem;
    font-family: var(--display);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    border-radius: 999px;
    border: 1px solid transparent;
    cursor: pointer;
    text-decoration: none !important;
    transition: background 160ms ease, border-color 160ms ease, color 160ms ease, transform 160ms ease;
    white-space: nowrap;
  }
  .landing-btn:hover { transform: translateY(-1px); }
  .landing-btn:active { transform: translateY(0); }

  .landing-btn--primary {
    background: var(--amber);
    color: oklch(0.16 0.012 60);
    border-color: var(--amber);
  }
  .landing-btn--primary:hover {
    background: var(--amber-2);
    border-color: var(--amber-2);
  }

  .landing-btn--ghost {
    background: transparent;
    color: var(--cream);
    border-color: var(--line);
  }
  .landing-btn--ghost:hover {
    border-color: var(--cream-3);
    background: var(--ink-2);
  }

  .landing-btn svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .landing-root *,
    .landing-root *::before,
    .landing-root *::after {
      animation-duration: 0ms !important;
      transition-duration: 0ms !important;
    }
  }
</style>

---
const pillars = [
  {
    n: '01',
    title: 'Errors as data.',
    body: 'Functions that fail return Result types — never thrown exceptions for expected failures. The compiler tracks every variant.',
    code: [
      { kind: 'cm', text: '// expected failures become typed values' },
      { kind: 'kw', text: 'return ' },
      { kind: 'fn', text: 'ok' },
      { kind: 'pun', text: '({ id, name });' },
      { kind: 'br' },
      { kind: 'kw', text: 'return ' },
      { kind: 'fn', text: 'err' },
      { kind: 'pun', text: '({ ' },
      { kind: 'id', text: 'type' },
      { kind: 'pun', text: ': ' },
      { kind: 'str ok', text: "'USER_NOT_FOUND'" },
      { kind: 'pun', text: ', userId });' },
    ],
  },
  {
    n: '02',
    title: 'Composes with await.',
    body: 'step() unwraps Results inside a normal async function. The happy path reads top-to-bottom, errors short-circuit the rest.',
    code: [
      { kind: 'kw', text: 'const ' },
      { kind: 'id', text: 'user' },
      { kind: 'pun', text: '  = ' },
      { kind: 'kw', text: 'await ' },
      { kind: 'fn', text: 'step' },
      { kind: 'pun', text: '(' },
      { kind: 'str', text: "'getUser'" },
      { kind: 'pun', text: ', () => deps.' },
      { kind: 'fn', text: 'getUser' },
      { kind: 'pun', text: '(id));' },
      { kind: 'br' },
      { kind: 'kw', text: 'const ' },
      { kind: 'id', text: 'order' },
      { kind: 'pun', text: ' = ' },
      { kind: 'kw', text: 'await ' },
      { kind: 'fn', text: 'step' },
      { kind: 'pun', text: '(' },
      { kind: 'str', text: "'getOrder'" },
      { kind: 'pun', text: ', () => deps.' },
      { kind: 'fn', text: 'getOrder' },
      { kind: 'pun', text: '(user.id));' },
      { kind: 'br' },
      { kind: 'kw', text: 'return ' },
      { kind: 'fn', text: 'fulfil' },
      { kind: 'pun', text: '(order);' },
    ],
  },
  {
    n: '03',
    title: 'Reliability built in.',
    body: 'Retries, timeouts, idempotency keys, save & resume — primitives, not afterthoughts. Add them where you need them, leave the rest untouched.',
    code: [
      { kind: 'kw', text: 'await ' },
      { kind: 'fn', text: 'step.retry' },
      { kind: 'pun', text: '(' },
      { kind: 'str', text: "'charge'" },
      { kind: 'pun', text: ', () => deps.' },
      { kind: 'fn', text: 'charge' },
      { kind: 'pun', text: '(amt), {' },
      { kind: 'br' },
      { kind: 'pun', text: '  ' },
      { kind: 'id', text: 'attempts' },
      { kind: 'pun', text: ': ' },
      { kind: 'str ok', text: '3' },
      { kind: 'pun', text: ',' },
      { kind: 'br' },
      { kind: 'pun', text: '  ' },
      { kind: 'id', text: 'backoff' },
      { kind: 'pun', text: ': ' },
      { kind: 'str', text: "'exponential'" },
      { kind: 'pun', text: ',' },
      { kind: 'br' },
      { kind: 'pun', text: '  ' },
      { kind: 'id', text: 'key' },
      { kind: 'pun', text: ': ' },
      { kind: 'str', text: '`charge:${order.idempotencyKey}`' },
      { kind: 'br' },
      { kind: 'pun', text: '});' },
    ],
  },
];
---

<section
  class="landing-section pillars sl-markdown-no-margin"
  aria-labelledby="pillars-heading"
>
  <div class="landing-inner">
    <header class="pillars__header">
      <span class="landing-eyebrow">03 · Why awaitly</span>
      <h2 class="landing-h2" id="pillars-heading">
        Three ideas. <em>That's the whole library.</em>
      </h2>
    </header>

    <div class="pillars__grid">
      {
        pillars.map((p) => (
          <article class="pillar">
            <div class="pillar__num" aria-hidden="true">
              {p.n}
            </div>
            <h3 class="pillar__title">{p.title}</h3>
            <p class="pillar__body">{p.body}</p>
            <pre class="pillar__code">
              <code>
                {p.code.map((t) =>
                  t.kind === 'br' ? (
                    <br />
                  ) : (
                    <span class={t.kind}>{t.text}</span>
                  ),
                )}
              </code>
            </pre>
          </article>
        ))
      }
    </div>
  </div>
</section>

---
const cols = [
  { key: 'awaitly', label: 'awaitly', sub: 'this library', highlight: true },
  { key: 'trycatch', label: 'try / catch', sub: 'JavaScript' },
  { key: 'neverthrow', label: 'neverthrow', sub: 'Result types' },
  { key: 'effect', label: 'Effect', sub: 'fp ecosystem' },
];

type Cell = { kind: 'yes' | 'no' | 'partial' | 'note'; text?: string };

const rows: { label: string; cells: Record<string, Cell> }[] = [
  {
    label: 'async / await syntax',
    cells: {
      awaitly: { kind: 'yes' },
      trycatch: { kind: 'yes' },
      neverthrow: { kind: 'partial', text: 'methods' },
      effect: { kind: 'partial', text: 'gens / pipe' },
    },
  },
  {
    label: 'errors typed from deps',
    cells: {
      awaitly: { kind: 'yes' },
      trycatch: { kind: 'no', text: 'unknown' },
      neverthrow: { kind: 'partial', text: 'manual unions' },
      effect: { kind: 'yes' },
    },
  },
  {
    label: 'retries / timeouts built in',
    cells: {
      awaitly: { kind: 'yes' },
      trycatch: { kind: 'no' },
      neverthrow: { kind: 'no' },
      effect: { kind: 'yes' },
    },
  },
  {
    label: 'pause / resume workflows',
    cells: {
      awaitly: { kind: 'yes' },
      trycatch: { kind: 'no' },
      neverthrow: { kind: 'no' },
      effect: { kind: 'partial', text: 'via fibers' },
    },
  },
  {
    label: 'learning curve',
    cells: {
      awaitly: { kind: 'note', text: 'one new fn' },
      trycatch: { kind: 'note', text: 'none' },
      neverthrow: { kind: 'note', text: 'low' },
      effect: { kind: 'note', text: 'runtime + DSL' },
    },
  },
];
---

<section class="landing-section compare" aria-labelledby="compare-heading">
  <div class="landing-inner">
    <header class="compare__header">
      <span class="landing-eyebrow">05 · Where it fits</span>
      <h2 class="landing-h2" id="compare-heading">
        Where <em>awaitly fits.</em>
      </h2>
      <p class="landing-lead">
        awaitly sits between <code>try/catch</code> and heavier FP runtimes:
        typed errors, <code>async/await</code>, no DSL to learn. Effect and
        neverthrow cover adjacent ground; pick the tool that matches how you
        already write TypeScript.
      </p>
    </header>

    <div class="compare__wrap">
      <table class="compare__table">
        <thead>
          <tr>
            <th scope="col" class="compare__th-label"></th>
            {
              cols.map((c) => (
                <th
                  scope="col"
                  class={`compare__th${c.highlight ? ' compare__th--mine' : ''}`}
                >
                  <span class="compare__col-label">{c.label}</span>
                  <span class="compare__col-sub">{c.sub}</span>
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            rows.map((row) => (
              <tr>
                <th scope="row" class="compare__row-label">
                  {row.label}
                </th>
                {cols.map((c) => {
                  const cell = row.cells[c.key];
                  return (
                    <td
                      class={`compare__cell compare__cell--${cell.kind}${c.highlight ? ' compare__cell--mine' : ''}`}
                    >
                      {cell.kind === 'yes' && (
                        <span
                          class="compare__mark compare__mark--yes"
                          aria-label="yes"
                        >
                          ●
                        </span>
                      )}
                      {cell.kind === 'no' && (
                        <span
                          class="compare__mark compare__mark--no"
                          aria-label="no"
                        >
                          ○
                        </span>
                      )}
                      {cell.kind === 'partial' && (
                        <span
                          class="compare__mark compare__mark--partial"
                          aria-label="partial"
                        >
                          ◐
                        </span>
                      )}
                      {cell.text && (
                        <span class="compare__cell-text">{cell.text}</span>
                      )}
                    </td>
                  );
                })}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</section>

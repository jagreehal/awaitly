---
const cols = [
  { key: 'awaitly',    label: 'awaitly',    sub: 'this library', highlight: true },
  { key: 'trycatch',   label: 'try / catch', sub: 'JavaScript' },
  { key: 'neverthrow', label: 'neverthrow', sub: 'Result types' },
  { key: 'effect',     label: 'Effect',     sub: 'fp ecosystem' },
];

type Cell = { kind: 'yes' | 'no' | 'partial' | 'note'; text?: string };

const rows: { label: string; cells: Record<string, Cell> }[] = [
  {
    label: 'async / await syntax',
    cells: {
      awaitly:    { kind: 'yes' },
      trycatch:   { kind: 'yes' },
      neverthrow: { kind: 'partial', text: 'methods' },
      effect:     { kind: 'partial', text: 'gens / pipe' },
    },
  },
  {
    label: 'errors typed automatically',
    cells: {
      awaitly:    { kind: 'yes' },
      trycatch:   { kind: 'no', text: 'unknown' },
      neverthrow: { kind: 'partial', text: 'manual unions' },
      effect:     { kind: 'yes' },
    },
  },
  {
    label: 'retries / timeouts built in',
    cells: {
      awaitly:    { kind: 'yes' },
      trycatch:   { kind: 'no' },
      neverthrow: { kind: 'no' },
      effect:     { kind: 'yes' },
    },
  },
  {
    label: 'pause / resume workflows',
    cells: {
      awaitly:    { kind: 'yes' },
      trycatch:   { kind: 'no' },
      neverthrow: { kind: 'no' },
      effect:     { kind: 'partial', text: 'via fibers' },
    },
  },
  {
    label: 'learning curve',
    cells: {
      awaitly:    { kind: 'note', text: 'one new fn' },
      trycatch:   { kind: 'note', text: 'none' },
      neverthrow: { kind: 'note', text: 'low' },
      effect:     { kind: 'note', text: 'a whole runtime' },
    },
  },
];
---

<section class="landing-section compare" aria-labelledby="compare-heading">
  <div class="landing-inner">
    <header class="compare__header">
      <span class="landing-eyebrow">04 · Where it fits</span>
      <h2 class="landing-h2" id="compare-heading">
        Honest <em>about the trade-offs.</em>
      </h2>
      <p class="landing-lead">
        Effect is excellent. neverthrow is excellent. <code>try/catch</code> works fine
        when types don't matter. awaitly sits in the middle: typed errors, async/await,
        no DSL to learn.
      </p>
    </header>

    <div class="compare__wrap">
      <table class="compare__table">
        <thead>
          <tr>
            <th scope="col" class="compare__th-label"></th>
            {cols.map((c) => (
              <th scope="col" class={`compare__th${c.highlight ? ' compare__th--mine' : ''}`}>
                <span class="compare__col-label">{c.label}</span>
                <span class="compare__col-sub">{c.sub}</span>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr>
              <th scope="row" class="compare__row-label">{row.label}</th>
              {cols.map((c) => {
                const cell = row.cells[c.key];
                return (
                  <td class={`compare__cell compare__cell--${cell.kind}${c.highlight ? ' compare__cell--mine' : ''}`}>
                    {cell.kind === 'yes' && <span class="compare__mark compare__mark--yes" aria-label="yes">●</span>}
                    {cell.kind === 'no' && <span class="compare__mark compare__mark--no" aria-label="no">○</span>}
                    {cell.kind === 'partial' && <span class="compare__mark compare__mark--partial" aria-label="partial">◐</span>}
                    {cell.text && <span class="compare__cell-text">{cell.text}</span>}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .compare {
    padding-block: clamp(4.5rem, 9vw, 7.5rem);
  }

  .compare__header {
    max-width: 64ch;
    margin-bottom: clamp(2.5rem, 5vw, 3.5rem);
  }
  .compare__header code {
    font-family: var(--mono);
    font-size: 0.88em;
    color: var(--cream);
    background: var(--ink-2);
    padding: 0.05em 0.35em;
    border-radius: 3px;
    border: 1px solid var(--line-soft);
  }

  .compare__wrap {
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    background: var(--ink-2);
  }

  .compare__table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--display);
    font-size: 0.9375rem;
    color: var(--cream-2);
  }

  .compare__table th,
  .compare__table td {
    padding: 1rem 1.125rem;
    text-align: left;
    vertical-align: middle;
    border-bottom: 1px solid var(--line-soft);
  }
  .compare__table tbody tr:last-child th,
  .compare__table tbody tr:last-child td {
    border-bottom: 0;
  }

  .compare__th {
    font-weight: 500;
    color: var(--cream-2);
    background: var(--ink);
    border-bottom: 1px solid var(--line);
    width: 18%;
  }
  .compare__th-label { width: 28%; background: var(--ink); }

  .compare__th--mine {
    background: oklch(from var(--amber) l c h / 0.10);
    border-bottom-color: var(--amber-dim);
  }
  .compare__th--mine .compare__col-label { color: var(--amber); }

  .compare__col-label {
    display: block;
    font-family: var(--display);
    font-weight: 600;
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
    color: var(--cream);
  }
  .compare__col-sub {
    display: block;
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cream-3);
    margin-top: 0.2rem;
  }

  .compare__row-label {
    font-weight: 500;
    color: var(--cream);
    font-size: 0.9375rem;
    letter-spacing: -0.005em;
    background: oklch(from var(--ink-2) l c h / 0.4);
  }

  .compare__cell {
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--cream-3);
    letter-spacing: -0.005em;
    display: table-cell;
  }
  .compare__cell--mine {
    background: oklch(from var(--amber) l c h / 0.05);
  }

  .compare__mark {
    font-size: 0.875rem;
    line-height: 1;
    margin-right: 0.5rem;
    display: inline-block;
    vertical-align: -1px;
  }
  .compare__mark--yes { color: var(--amber); }
  .compare__mark--no  { color: oklch(from var(--rust) l c h / 0.7); }
  .compare__mark--partial { color: var(--cream-3); }

  .compare__cell-text {
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--cream-2);
  }

  /* Mobile: stack each column, less hostile than h-scroll */
  @media (max-width: 50rem) {
    .compare__wrap {
      overflow-x: auto;
    }
    .compare__table {
      min-width: 36rem;
    }
  }
</style>

---
---

<section class="landing-section cta">
  <div class="landing-inner cta__inner">
    <div class="cta__lockup">
      <span class="landing-eyebrow">Start writing it</span>
      <h2 class="cta__headline">
        Async code your compiler can <em>typecheck.</em>
      </h2>
      <p class="cta__lead">
        Five minutes to your first typed workflow. Just <code>async/await</code>,
        Result types, and inferred error unions.
      </p>

      <div class="cta__actions">
        <a href="getting-started/installation/" class="landing-btn landing-btn--primary">
          Install awaitly
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="getting-started/first-workflow/" class="landing-btn landing-btn--ghost">
          Build your first workflow
        </a>
      </div>
    </div>

    <div class="cta__glyph" aria-hidden="true">
      <span class="cta__tick">awaitly</span>
      <span class="cta__sig">Good things come to those who a-<em>wait</em>-ly.</span>
    </div>
  </div>

  <footer class="cta__footer">
    <div class="landing-inner cta__footer-inner">
      <span class="cta__footer-meta">awaitly · MIT licensed · v1.30.2</span>
      <nav class="cta__footer-nav" aria-label="Footer">
        <a href="reference/api/">API</a>
        <a href="comparison/">Comparison</a>
        <a href="https://github.com/jagreehal/awaitly">GitHub</a>
        <a href="https://www.npmjs.com/package/awaitly">npm</a>
      </nav>
    </div>
  </footer>
</section>

<style>
  .cta {
    padding-block: clamp(5rem, 10vw, 8rem) 0;
    background:
      radial-gradient(800px 400px at 80% 0%, oklch(from var(--amber) l c h / 0.08), transparent 70%),
      var(--ink);
    position: relative;
  }

  .cta__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(2.5rem, 5vw, 4rem);
    padding-bottom: clamp(4rem, 8vw, 6.5rem);
    align-items: center;
  }
  @media (min-width: 64rem) {
    .cta__inner { grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr); }
  }

  .cta__headline {
    font-family: var(--display);
    font-weight: 700;
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    line-height: 1.04;
    letter-spacing: -0.03em;
    color: var(--cream);
    margin: 1.25rem 0 0;
    text-wrap: balance;
  }
  .cta__headline em {
    font-style: italic;
    color: var(--amber);
    font-weight: 600;
  }

  .cta__lead {
    font-family: var(--display);
    font-size: clamp(1rem, 1.4vw, 1.125rem);
    line-height: 1.55;
    color: var(--cream-2);
    max-width: 56ch;
    margin: 1.25rem 0 0;
  }
  .cta__lead code {
    font-family: var(--mono);
    font-size: 0.88em;
    background: var(--ink-2);
    padding: 0.05em 0.35em;
    border-radius: 3px;
    color: var(--cream);
    border: 1px solid var(--line-soft);
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .cta__glyph {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: clamp(1.5rem, 3vw, 2rem);
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--ink-2);
  }
  .cta__tick {
    font-family: var(--display);
    font-weight: 800;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--amber);
    font-style: italic;
  }
  .cta__sig {
    font-family: var(--display);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.45;
    color: var(--cream-2);
    border-top: 1px solid var(--line-soft);
    padding-top: 1rem;
  }
  .cta__sig em {
    font-style: normal;
    font-weight: 700;
    color: var(--amber);
  }

  .cta__footer {
    border-top: 1px solid var(--line-soft);
    padding-block: 1.5rem;
    background: oklch(from var(--ink) l c h / 0.7);
  }
  .cta__footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    align-items: center;
    justify-content: space-between;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--cream-3);
    letter-spacing: 0.02em;
  }
  .cta__footer-meta {
    color: var(--cream-3);
  }
  .cta__footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }
  .cta__footer-nav a {
    color: var(--cream-2);
    text-decoration: none;
    transition: color 160ms ease;
  }
  .cta__footer-nav a:hover { color: var(--amber); }
</style>

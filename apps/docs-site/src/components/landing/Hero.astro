---
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

const logoPath = fileURLToPath(new URL('../../../public/logo-animated.svg', import.meta.url));
const logoSvg = readFileSync(logoPath, 'utf-8');
---

<section class="landing-section landing-section--first hero">
  <div class="landing-inner hero__inner">
    <div class="hero__content">
      <div class="hero__eyebrow">
        <span class="hero__logo" aria-hidden="true" set:html={logoSvg} />
        <span class="landing-eyebrow hero__eyebrow-text">awaitly · v1.30</span>
      </div>

      <h1 class="hero__headline">
        <span class="hero__line hero__line--1">Errors as data,</span>
        <span class="hero__line hero__line--2">in <em>async/await</em>.</span>
      </h1>

      <p class="hero__lead">
        awaitly returns errors as data, infers their types from your dependencies,
        and composes async steps without <code>try/catch</code>.
        The familiar syntax you already write — with the safety you wish it had.
      </p>

      <div class="hero__actions">
        <a href="getting-started/installation/" class="landing-btn landing-btn--primary">
          Get started
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <a href="getting-started/basics/" class="landing-btn landing-btn--ghost">
          Read the basics
        </a>
      </div>

      <div class="hero__quick">
        <code class="hero__install">npm install awaitly</code>
        <a href="https://github.com/jagreehal/awaitly" class="hero__github" aria-label="View source on GitHub">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.24 3.34.95.1-.74.4-1.24.72-1.53-2.55-.29-5.23-1.27-5.23-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.17a10.96 10.96 0 0 1 5.74 0c2.19-1.48 3.15-1.17 3.15-1.17.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.07 0 4.4-2.69 5.36-5.25 5.65.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"/>
          </svg>
          <span>jagreehal/awaitly</span>
        </a>
      </div>

      <aside class="hero__strip" aria-hidden="true">
        <div class="hero__strip-item">
          <span class="hero__strip-label">Bundled</span>
          <span class="hero__strip-value">Result · Workflow · step()</span>
        </div>
        <div class="hero__strip-item">
          <span class="hero__strip-label">Built in</span>
          <span class="hero__strip-value">Retries · Timeouts · Resume · Idempotency</span>
        </div>
        <div class="hero__strip-item">
          <span class="hero__strip-label">Inferred</span>
          <span class="hero__strip-value">Every error union, automatically</span>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(4.5rem, 10vw, 8.5rem);
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(900px 500px at 8% -10%, oklch(0.30 0.04 65 / 0.55), transparent 60%),
      radial-gradient(700px 400px at 100% 110%, oklch(0.28 0.03 60 / 0.45), transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  :where([data-theme='light']) .hero::before {
    background:
      radial-gradient(900px 500px at 8% -10%, oklch(0.92 0.04 65 / 0.65), transparent 60%),
      radial-gradient(700px 400px at 100% 110%, oklch(0.94 0.03 60 / 0.55), transparent 60%);
  }
  .hero__inner { position: relative; z-index: 1; }

  .hero__content {
    max-width: 60rem;
  }

  .hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }
  .hero__logo {
    display: inline-flex;
    width: 28px;
    height: 28px;
  }
  .hero__logo :global(svg) {
    width: 100%;
    height: 100%;
  }
  .hero__eyebrow-text {
    color: var(--cream-2);
  }

  .hero__headline {
    font-family: var(--display);
    font-weight: 700;
    font-size: clamp(2rem, 5.6vw, 4.75rem);
    line-height: 1.02;
    letter-spacing: -0.035em;
    margin: 0;
    color: var(--cream);
    text-wrap: balance;
  }
  .hero__line {
    display: block;
  }
  .hero__line--2 {
    color: var(--cream-2);
  }
  .hero__line--2 em {
    font-style: italic;
    font-weight: 800;
    color: var(--amber);
    letter-spacing: -0.05em;
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero__line {
      animation: hero-rise 700ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
    }
    .hero__line--2 { animation-delay: 120ms; }
  }
  @keyframes hero-rise {
    from { transform: translateY(0.3em); }
    to   { transform: translateY(0); }
  }

  .hero__lead {
    font-size: clamp(1.0625rem, 1.4vw, 1.25rem);
    line-height: 1.55;
    color: var(--cream-2);
    max-width: 56ch;
    margin: clamp(1.5rem, 3vw, 2.25rem) 0 0;
  }
  .hero__lead code {
    font-family: var(--mono);
    font-size: 0.92em;
    background: var(--ink-2);
    padding: 0.1em 0.4em;
    border-radius: 4px;
    color: var(--cream);
    border: 1px solid var(--line-soft);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: clamp(2rem, 4vw, 2.75rem);
  }

  .hero__quick {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem 1.5rem;
    margin-top: clamp(2rem, 4vw, 2.75rem);
    padding-top: 1.5rem;
    border-top: 1px solid var(--line-soft);
  }
  .hero__install {
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--cream-2);
    letter-spacing: -0.01em;
  }
  .hero__install::before {
    content: '$ ';
    color: var(--amber);
    margin-right: 0.25rem;
  }
  .hero__github {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--cream-3);
    text-decoration: none !important;
    font-size: 0.8125rem;
    font-family: var(--mono);
    transition: color 160ms ease;
  }
  .hero__github:hover { color: var(--cream); }
  .hero__github svg { width: 14px; height: 14px; }

  .hero__strip {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1.25rem 2.5rem;
    margin-top: clamp(2.5rem, 5vw, 4rem);
    padding-top: 1.75rem;
    border-top: 1px solid var(--line-soft);
  }
  @media (min-width: 48rem) {
    .hero__strip { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  .hero__strip-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .hero__strip-label {
    font-family: var(--mono);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cream-3);
  }
  .hero__strip-value {
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--cream-2);
    letter-spacing: -0.01em;
    line-height: 1.45;
  }
</style>

{
  "name": "awaitly",
  "version": "2.0.0",
  "type": "module",
  "description": "Typed async workflows with automatic error inference. Build type-safe workflows with Result types, step caching, resume state, and human-in-the-loop support.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./result": {
      "types": "./dist/result.d.ts",
      "import": "./dist/result.js",
      "require": "./dist/result.cjs"
    },
    "./run": {
      "types": "./dist/run.d.ts",
      "import": "./dist/run.js",
      "require": "./dist/run.cjs"
    },
    "./workflow": {
      "types": "./dist/workflow.d.ts",
      "import": "./dist/workflow.js",
      "require": "./dist/workflow.cjs"
    },
    "./reliability": {
      "types": "./dist/reliability.d.ts",
      "import": "./dist/reliability.js",
      "require": "./dist/reliability.cjs"
    },
    "./durable": {
      "types": "./dist/durable.d.ts",
      "import": "./dist/durable.js",
      "require": "./dist/durable.cjs"
    },
    "./persistence": {
      "types": "./dist/persistence.d.ts",
      "import": "./dist/persistence.js",
      "require": "./dist/persistence.cjs"
    },
    "./saga": {
      "types": "./dist/saga.d.ts",
      "import": "./dist/saga.js",
      "require": "./dist/saga.cjs"
    },
    "./hitl": {
      "types": "./dist/hitl.d.ts",
      "import": "./dist/hitl.js",
      "require": "./dist/hitl.cjs"
    },
    "./streaming": {
      "types": "./dist/streaming.d.ts",
      "import": "./dist/streaming.js",
      "require": "./dist/streaming.cjs"
    },
    "./webhook": {
      "types": "./dist/webhook.d.ts",
      "import": "./dist/webhook.js",
      "require": "./dist/webhook.cjs"
    },
    "./engine": {
      "types": "./dist/engine.d.ts",
      "import": "./dist/engine.js",
      "require": "./dist/engine.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint .",
    "clean": "rm -rf dist",
    "tsd": "tsd --files src/index.test-d.ts",
    "quality": "pnpm type-check && pnpm test && pnpm build && pnpm tsd && pnpm lint"
  },
  "keywords": [
    "awaitly",
    "workflow",
    "workflows",
    "result",
    "result-type",
    "error-handling",
    "typescript",
    "async",
    "async-await",
    "type-safe",
    "type-inference",
    "railway-oriented-programming",
    "functional-programming",
    "either",
    "monad",
    "step",
    "orchestration",
    "pipeline",
    "early-exit",
    "resume",
    "caching",
    "hitl",
    "human-in-the-loop"
  ],
  "author": "Jag Reehal <jag@jagreehal.com>",
  "homepage": "https://github.com/jagreehal/awaitly#readme",
  "bugs": {
    "url": "https://github.com/jagreehal/awaitly/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jagreehal/awaitly.git"
  },
  "license": "MIT",
  "peerDependencies": {
    "@standard-schema/spec": "1.1.0"
  },
  "peerDependenciesMeta": {
    "@standard-schema/spec": {
      "optional": true
    }
  },
  "devDependencies": {
    "@standard-schema/spec": "1.1.0",
    "@total-typescript/ts-reset": "0.6.1",
    "@total-typescript/tsconfig": "1.0.4",
    "@types/node": "25.9.3",
    "@types/picomatch": "4.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "pino": "10.3.1",
    "tsd": "0.33.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=22"
  },
  "tsd": {
    "compilerOptions": {
      "noUnusedLocals": false,
      "noUnusedParameters": false
    }
  }
}
